{
  "name": "e60-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "E6.0 — ESG platform for European banks · Nfq Advisory",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "dev": "pnpm --filter @e60/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "type-check": "pnpm -r type-check",
    "test": "pnpm -r --if-present --no-bail test",
    "test:coverage": "pnpm -r --if-present --no-bail test:coverage",
    "format": "prettier --write .",
    "clean": "pnpm -r clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "19",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.4",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.3.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.59.3",
    "vitest": "^3.2.4"
  }
}
