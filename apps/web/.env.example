# E6.0 web app · environment variables
#
# Copy this file to .env.local and adjust for your local setup.
# .env.local is gitignored.

# Backend API base URL. In dev, this typically points at a local FastAPI
# instance or the staging environment.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Supabase project · direct DB + auth from the frontend via @supabase/ssr.
# These two are auto-injected by the Supabase Vercel Integration in prod /
# preview. For local dev copy them from Supabase Dashboard → Settings → API.
# The anon key is public-facing; service-role key NEVER goes here.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Optional · tenant ID for multi-tenant deployments (banking clients).
# Leave empty for single-tenant dev.
NEXT_PUBLIC_TENANT=pilot-bank-iberia

# ALQUID Net Zero base URL. When set, the Financed Emissions and Net-Zero
# Trajectory routes embed `${BASE}/embed/{view}` via iframe. Leave empty in
# dev to render the "Not connected" placeholder.
NEXT_PUBLIC_ALQUID_NZ_BASE_URL=

# CBAM Engine base URL. When set, /sustainable-finance/cbam embeds
# `${BASE}/embed/{view}` via iframe (Carbon Border Adjustment Mechanism
# imports + certificate exposure).
NEXT_PUBLIC_CBAM_BASE_URL=
